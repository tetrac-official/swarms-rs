# =============================================================================
# swarms-RS
# =============================================================================
RUST_LOG=debug

SWARMS_LOG_LEVEL=DEBUG

OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Or for DeepSeek
DEEPSEEK_API_KEY="your_deepseek_key_here"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

ANTHROPIC_API_KEY=""

# =============================================================================
# swarms-tetrac — TTC session
# Auto-populated by `skill-trading register` (first time) and refreshed by
# `skill-trading login` (24h tokens). Run from this directory.
# =============================================================================
TTC_AUTH_TOKEN=
TTC_PUBLIC_KEY=

# Optional — defaults shown.
# TTC_BASE_URL=https://ttc.box/api/v1
# TTC_DEFAULT_EXCHANGE=orderly
# TTC_DRY_RUN=true                   # mutating tools synthesize success when true
# TTC_MAX_LOOPS_PER_MINUTE=60

# Required only when targeting Orderly with an email-registered account.
ORDERLY_MAIN_WALLET_ADDRESS=

# =============================================================================
# Per-exchange credentials
# Source of truth: TTC/next-ttc/src/utils/exchange/tools/exchangeList.ts
# Set only the exchanges your agent will actually trade on.
# =============================================================================

